acr_admin_enabled       = false
enable_monitoring       = true
log_retention_days      = 30

common_tags = {
  Project     = "Kazestack"
  ManagedBy   = "Terraform"
  CreatedBy   = "DevOps"
  Environment = "Production"
  CostCenter  = "Engineering"
}
